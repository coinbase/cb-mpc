{
  "name": "cb-mpc-web",
  "version": "1.0.0",
  "description": "Coinbase MPC Library - Web & JavaScript Implementation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:wasm",
    "build:wasm": "wasm-pack build wasm/mpc --target web --out-dir ../../src/wasm",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .js,.ts,.jsx,.tsx",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,css,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "bignumber.js": "^9.1.1",
    "noble-secp256k1": "^1.7.0",
    "noble-ed25519": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.1.1",
    "wasm-pack": "^1.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
